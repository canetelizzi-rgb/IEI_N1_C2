# Operadores ARITMETICOS

numero_1 = 45
numero_2 = 12
numero_3 = 0

#operador suma
print()
suma = numero_1 + numero_2
print(suma)
print(type(suma))

# operador resta
print()
resta = numero_1 - numero_2
print(resta)
print(type(resta))

# operador multiplicacion
print()
multiplicacion = numero_1 * numero_2
print(multiplicacion)
print(type(multiplicacion))

# operador division
print()
division = numero_1/ numero_2
print(division)
print(type(division))
